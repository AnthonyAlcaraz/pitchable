# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pitchable
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Redis (Railway provides REDIS_URL; otherwise use host/port)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pitchable-documents

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
REPLICATE_API_TOKEN=

# Image Hosting
IMGUR_CLIENT_ID=

# Email
RESEND_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PACK_10_PRICE_ID=
STRIPE_PACK_25_PRICE_ID=
STRIPE_PACK_50_PRICE_ID=

# EdgeQuake Graph-RAG (optional)
EDGEQUAKE_ENABLED=false
EDGEQUAKE_URL=http://edgequake:8080
EDGEQUAKE_API_KEY=

# ZeroEntropy (optional)
ZEROENTROPY_API_KEY=

# Error Monitoring (optional)
SENTRY_DSN=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database Backups (optional)
ENABLE_DB_BACKUPS=false
